# Devin (peon1.py)
DEVIN_API_KEY=your_devin_api_key_here
DEVIN_ORG_ID=your_devin_org_id_here
SELF_USER_ID=your_devin_user_id_here

# Devin account tier — set to true if you have the ViewAccountSessions enterprise permission
# docs.devin.ai/api-reference/v3/sessions/get-enterprise-session-messages.md
DEVIN_ENTERPRISE=false

# GitHub (issue_listener.py)
GITHUB_TOKEN=your_github_token_here

# Redis (issue_listener.py — defaults shown)
REDIS_HOST=localhost
REDIS_PORT=6379

# NVD (nvd_listener.py — API key optional but raises rate limit)
NVD_API_KEY=your_nvd_api_key_here

# Tuning (defaults shown)
ISSUE_LISTENER_SLEEP_PERIOD_SECONDS=300
NVD_LISTENER_SLEEP_PERIOD_SECONDS=300
CVE_MITRE_LISTENER_SLEEP_PERIOD_SECONDS=300
